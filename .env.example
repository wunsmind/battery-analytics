# Your Tibber Developer API token: https://developer.tibber.com/settings/access-token
# Tibber also publishes a public DEMO token you can use for testing without a real account:
#   TIBBER_TOKEN=3A77EECF61BD445F47241A5A36202185C8AF7B5BD6C504AFACE6CCBF1E9C746D
TIBBER_TOKEN=your-token-here

# Path to the SQLite database file (default: prices.db in the project root)
DB_PATH=prices.db
